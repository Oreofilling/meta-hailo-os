/*
 * Hailo15 NE503 (AM20-01-V1.0), aligned to hailo15-sbc-rev3-1.
 * With interface board CF66-01-V1.0: TF card on SDIO0 (VDD_SDCARD select on GPIO17),
 * NAU88C10 audio on I2C0 + I2S (H_I2C0_*, H_I2S_*).
 * Copyright (c) 2019-2025 Hailo Technologies Ltd. All rights reserved.
 */

/dts-v1/;
#include "hailo15-base.dtsi"
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "Hailo - Hailo15 NE503 (AM20-01) VPU Development Board";

	memory {
		device_type = "memory";
		reg = <0x00 0x00000000 0x02 0x00000000>;
	};
};

&i2c_0 {
	status = "ok";
	i2c-sda-falling-time-ns = <1000>;

	/* CF66-01: NAU88C10 on H_I2C0; use NAU8810 driver (nuvoton,nau8810) for compatibility */
	codec_nau88c10: nau88c10@1a {
		#sound-dai-cells = <0>;
		compatible = "nuvoton,nau8810", "nuvoton,nau88c10";
		reg = <0x1a>;
	};

};

&sensor_0 {
    status = "ok";
	reg = <0x10>;
    reset-gpios = <&gpio0 8 GPIO_ACTIVE_HIGH>;
    xmaster-gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>;
};

&i2c_1 {
	status = "ok";
	i2c-sda-falling-time-ns = <1000>;

	tmp1075_temp: tmp1075@49 {
		compatible = "ti,tmp1075";
		reg = <0x49>;
	};

	eeprom: eeprom@50 {
		compatible = "atmel,24c02";
		reg = <0x50>;
	};
};

&i2c_2 {
	status = "okay";
	i2c-sda-falling-time-ns = <190>;
	clock-frequency = <400000>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_i2c2>;
	gyro_lsm6dsr: lsm6dsr@6a {
		status = "okay";
		compatible = "st,lsm6dsr";
		reg = <0x6a>;
		vdd-supply = <&regulator_1p8v>;
		vddio-supply = <&regulator_1p8v>;
		interrupt-parent = <&gpio1>;
		interrupts = <11 IRQ_TYPE_LEVEL_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_gpio27>;
	};
};

&csi2rx0 {
	status = "ok";
	ports {
		port@0 {
			csi2rx_in_sensor: endpoint {
				remote-endpoint = <&sensor_out_csi2rx>;
			};
		};
	};
};

&csi2rx1 {
	status = "disabled";
};

&vision_subsys {
	status = "okay";
};

&hailo_vid_cap {
	status = "ok";
};

&hailo_isp {
	status = "ok";
};

&hailo_pixel_mux {
	status = "ok";
};

&rxwrapper0 {
	status = "ok";
};

&hailo_vc8000e {
	status = "ok";
};

&xrp {
	status = "okay";
};

&xrp_reserved {
	status = "okay";
};

/* NE503+CF66: TF card on interface board; GPIO17 = VDD_SDCARD select (CF66-01 p.9) */
&sdio0 {
	status = "okay";
	bus-width = <4>;
	broken-cd;
	sd-vsel-gpio = <&gpio1 1 GPIO_ACTIVE_HIGH>;
	sd-vsel-polarity-high;
	sdhci-caps = <0x00000000 0x01000000>;
	/* Force VOLT33, disable UHS modes, and cap clock for stable operation */
	sdhci-caps-mask = <0x00000007 0x00000000>;
	max-frequency = <25000000>;
	phy-config {
		card-is-emmc = <0x0>;
		cmd-pad-values = <0x1 0x3 0x1 0x1>;
		dat-pad-values = <0x1 0x3 0x1 0x1>;
		rst-pad-values = <0x1 0x3 0x1 0x1>;
		clk-pad-values = <0x1 0x3 0x0 0x1>;
		sdclkdl-cnfg = <0x1 0x13>;
		drive-strength = <0x8 0x4>;
	};
};

&sdio1 {
	status = "okay";
	non-removable;
	bus-width = <4>;
	phy-config {
		card-is-emmc = <0x1>;
		cmd-pad-values = <0x2 0x2 0x1 0x1>;
		dat-pad-values = <0x2 0x2 0x1 0x1>;
		rst-pad-values = <0x2 0x2 0x1 0x1>;
		clk-pad-values = <0x2 0x2 0x0 0x0>;
		sdclkdl-cnfg = <0x0 0x2C>;
		drive-strength = <0x9 0x7>;
	};
};

/* AM20-01: RMII + LAN8720AI (actual PHY address 0x01 confirmed via MDIO scan) */
&eth {
	status = "ok";
	phy-mode = "rmii";
	phy-handle = <&eth_phy0>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_eth>;
	eth_phy0: ethernet-phy@1 {
		compatible = "ethernet-phy-id0007.c0f0";
		reg = <1>;
	};
};

/* AM20-01: 8MB QSPI (e.g. IS25WP064D), CS0 only */
&qspi {
	status = "ok";
	spi0_flash0: flash@0 {
		spi-max-frequency = <6250000>;
		cdns,read-delay = <7>;
		cdns,tshsl-ns = <30>;
		cdns,tsd2d-ns = <30>;
		cdns,tchsh-ns = <5>;
		cdns,tslch-ns = <3>;
	};
};

/* CF66-01: NAU88C10 on I2C0 + I2S (H_I2S_*, 12.288MHz MCLK) */
&i2s_cpu_master {
	status = "okay";
	rx-sample-pace-pattern-repetitions = <2>;
	rx-sample-pace = <64 64 64>;
	rx-sample-cmp-to = "prev-val";
	tx-sample-offset = <81>;
	tx-sample-pace = <63>;
};

&audio_card_master {
	status = "ok";
	simple-audio-card,bitclock-master = <&cpu_dai_master>;
	simple-audio-card,frame-master = <&cpu_dai_master>;
	cpu_dai_master: simple-audio-card,cpu {
		sound-dai = <&i2s_cpu_master>;
		system-clock-frequency = <12288000>;
		system-clock-direction-out;
	};
	codec_dai_master: simple-audio-card,codec {
		sound-dai = <&codec_nau88c10>;
		system-clock-frequency = <12288000>;
	};
};

/* Slave TX/RX I2S controllers share the same IRQ as master;
 * the designware-i2s driver does not support IRQF_SHARED,
 * so only the master controller can be active.
 * Master handles both TX and RX via SCU DMA — sufficient for NAU88C10. */

&sdio0_reserved {
	status = "ok";
};

&serial0 {
	status = "ok";
};

/* CF66: UART2 to STM32G0 (Radar, IR, Alarm, RS-485, Wiegand, LENS protocol) */
&serial2 {
	status = "ok";
};

&pinctrl {
	pinctrl_eth: eth {
		pins = "eth_rgmii_tx_clk",
		       "eth_rgmii_tx_ctl",
		       "eth_rgmii_txd_0",
		       "eth_rgmii_txd_1",
		       "eth_rgmii_txd_2",
		       "eth_rgmii_txd_3";
		drive-strength = <2>;
	};

	pinctrl_i2c2: i2c2 {
		function = "i2c2";
		groups = "i2c2_0_grp";
	};

	pinctrl_usb_overcurrent_n_in: pinctrl_usb_overcurrent_n_in {
		status = "disabled"; /* relevant to USB overcurrent detection is not supported */
		function = "usb_overcurrent_in";
		groups = "usb_overcurrent_in_grp";
	};

	pinctrl_usb_drive_vbus_out: pinctrl_usb_drive_vbus_out {
		function = "usb_drive_vbus_out";
		groups = "usb_drive_vbus_out_2_grp";
	};

	pinctrl_gpio27: gpio27 {
		function = "gpio";
		groups = "gpio27_grp";
	};
};

/* AM20-01/CF66: pin names; GPIO17 = sdcard_vdd_sel (CF66 TF card) */
#define GPIO_LINE_NAMES \
	"gpio_in_out_0",            "gpio_in_out_1",            "gpio_in_out_2",            "gpio_in_out_3", \
	"gpio_in_out_4",            "gpio_in_out_5",            "gpio_in_out_6",            "gpio_in_out_7", \
	"cam0_reset_n",             "sdio0_gp_in",              "sdio0_cd_in",              "usb_overcurrent_n_in", \
	"usb_drive_vbus_out",       "sdio1_gp_in",              "sdio1_cd_in_n",            "PCIe_mperst_out", \
	\
	"gpio_in_out_16",           "sdcard_vdd_sel",            "timer_ext_in0",            "timer_ext_in1", \
	"shut_down_out",            "user_LED",                 "gpio_in_out_22",           "gpio_in_out_23", \
	"i2c2_current_src_en_out",  "i2c0_current_src_en_out",  "i2c1_current_src_en_out",  "gyro_int", \
	"ir_cut_en",                "gpio_in_out_29",           "uart0_cts_pad_in",         "uart0_rts_pad_out"

&gpio0 {
	gpio-ranges = <&pinctrl 0 0 16>;
	gpio-line-names = GPIO_LINE_NAMES;

	/* J1(M.2): RST GPIO15 Active-Low; output-high de-asserts PERST# */
	pin_M2_perst_n {
		gpio-hog;
		gpios = <15 0>;
		output-high;
		line-name = "PCIe_mperst_out";
	};
};

&gpio1 {
	gpio-ranges = <&pinctrl 0 16 16>;
	gpio-line-names = GPIO_LINE_NAMES;
};

&hailo_torrent_phy {
	status = "okay";
	usb-lane = <3>;
	usb-lane-pma-pll-full-rate-divider = <PCI_PMA_PLL_FULL_RATE_CLK_DIVIDER_4>;
	lanes-config = <PCI_PHY_LINK_LANES_CFG__2x1_PLUS_1x2__MASTER_LANES_LN0_LN2_LN3>;
};

&cdns_torrent_phy {
	torrent_phy_pcie: phy@0 {
		reg = <0>;
		resets = <&scmi_reset HAILO15_SCMI_RESET_IDX_PCIE_PHY_LANE_0>, <&scmi_reset HAILO15_SCMI_RESET_IDX_PCIE_PHY_LANE_1>;
		#phy-cells = <0>;
		cdns,phy-type = <PHY_TYPE_PCIE>;
		cdns,num-lanes = <2>;
	};
	torrent_phy_usb3: phy@3 {
		reg = <3>;
		resets = <&scmi_reset HAILO15_SCMI_RESET_IDX_PCIE_PHY_LANE_3>;
		#phy-cells = <0>;
		cdns,phy-type = <PHY_TYPE_USB3>;
		cdns,num-lanes = <1>;
		cdns,ssc-mode = <TORRENT_SERDES_NO_SSC>;
	};
};

&hailo_usb3 {
	status = "okay";
	/* Override OC pin in SW so controller never reports over-current (avoids IRQ storm / high CPU) */
	disconnected-overcurrent;
};

&cdns_usb3 {
	dr_mode = "host";
	phys = <&torrent_phy_usb3>;
	phy-names = "cdns3,usb3-phy";
	pinctrl-names = "default";
    pinctrl-0 = <&pinctrl_usb_drive_vbus_out>;
};

&reserved_memory {
	hailo_media_buf_cma: hailo_media_buf,cma {
		reg = <0 0x88000000 0 0x30000000>;
	};
};
